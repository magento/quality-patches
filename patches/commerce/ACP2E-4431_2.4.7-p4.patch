+    /**
+     * Update relation between rules and products
+     *
+     * @param array $existingEntities
+     * @param array $newEntities
+     * @return void
+     */
+    private function updateIndex(array $existingEntities, array $newEntities): void
+    {
+        $entitiesToDelete = [];
+        $entitiesToInsert = [];
+        foreach ($newEntities as $ruleId => $productIds) {
+            if (!empty($existingEntities[$ruleId])) {
+                $currentProductIds = $existingEntities[$ruleId];
+                sort($currentProductIds);
+                sort($productIds);
+                if ($productIds === $currentProductIds) {
+                    continue;
+                } else {
+                    $diffToDelete = array_diff($currentProductIds, $productIds);
+                    if (!empty($diffToDelete)) {
+                        $entitiesToDelete[$ruleId] = $diffToDelete;
+                    }
+                    $diffToInsert = array_diff($productIds, $currentProductIds);
+                    if (!empty($diffToInsert)) {
+                        $entitiesToInsert[$ruleId] = $diffToInsert;
+                    }
+                }
+            } else {
+                $entitiesToInsert[$ruleId] = $productIds;
+            }
+            $newRuleIds = array_keys($newEntities);
+            $existingRuleIds = array_keys($existingEntities);
+            $rulesToDelete = array_diff($existingRuleIds, $newRuleIds);
+            if (!empty($rulesToDelete)) {
+                $entitiesToDelete[$ruleId] = $existingEntities[$ruleId];
+            }
+            $this->_resource->updateIndex($entitiesToDelete, $entitiesToInsert);
+        }
+    }
