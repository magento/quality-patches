+    /**
+     * Update relation table with deletion and insertion new entities
+     *
+     * @param array $delete
+     * @param array $insert
+     * @return void
+     */
+    public function updateIndex(array $delete, array $insert): void
+    {
+        $connection = $this->getConnection();
+        $connection->beginTransaction();
+        $relationTable = $this->getTable(self::RELATION_TABLE);
+
+        if (!empty($delete)) {
+            $where = [];
+            foreach ($delete as $ruleId => $productIds) {
+                if (!empty($productIds)) {
+                    $where[] = $connection->quoteInto('(rule_id=' . $ruleId . ' AND product_id IN (?))', $productIds);
+                }
+            }
+            $connection->delete($relationTable, implode(' OR ', $where));
+        }
+
+        if (!empty($insert)) {
+            $data = [];
+            $count = 0;
+            foreach ($insert as $ruleId => $productIds) {
+                foreach ($productIds as $productId) {
+                    $data[] = [
+                        'product_id' => $productId,
+                        'rule_id' => $ruleId,
+                    ];
+                    $count++;
