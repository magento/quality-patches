+/**
+ * Retry configuration for transient DB lock conflicts.
+ */
+class RetryConfiguration implements RetryConfigurationInterface
+{
+    /**
+     * @var int
+     */
+    private $retryAttempts;
+
+    /**
+     * @var int
+     */
+    private $retryBaseDelay;
+
+    /**
+     * @var int
